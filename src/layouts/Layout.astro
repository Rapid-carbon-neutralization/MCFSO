<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>MCFSO - 新生MC服务器宣传组织</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
	<body>
		<slot />
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('server-search');
				if (!searchInput) return;
				searchInput.addEventListener('input', () => {
					const q = searchInput.value.toLowerCase().trim();
					const grid = document.getElementById('server-grid');
					if (!grid) return;
					const cards = grid.querySelectorAll('[data-server-name]');
					const empty = document.getElementById('empty-state');
					const count = document.getElementById('server-count');
					let visibleCount = 0;
					cards.forEach((card) => {
						const name = (card.getAttribute('data-server-name') || '').toLowerCase();
						if (name.includes(q)) {
							card.style.display = '';
							visibleCount++;
						} else {
							card.style.display = 'none';
						}
					});
					if (empty) empty.hidden = visibleCount > 0;
					if (count) count.textContent = visibleCount;
				});
			});
		</script>
	</body>
</html>

