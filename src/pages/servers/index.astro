---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ServerCard from '../../components/ServerCard.astro';
import { getCollection } from 'astro:content';

const allServers = await getCollection('servers');
const sorted = allServers
  .map((entry) => ({
    slug: entry.id,
    name: entry.data.name,
    icon: entry.data.icon,
    description: entry.data.description,
  }))
  .sort((a, b) => a.name.localeCompare(b.name, 'zh-CN'));
---

<Layout>
  <Header />
  <main class="list-page">
    <div class="list-header">
      <h2 class="list-title">服务器列表</h2>
      <p class="list-count"><span id="server-count">{sorted.length}</span> 个服务器</p>
    </div>
    <div class="card-grid" id="server-grid">
      {sorted.map((server) => (
        <ServerCard
          name={server.name}
          icon={server.icon}
          description={server.description}
          slug={server.slug}
        />
      ))}
    </div>
    <div id="empty-state" class="empty-state" hidden>
      <p>没有找到匹配的服务器</p>
    </div>
  </main>
</Layout>

<style>
  .list-page {
    background: var(--canvas-parchment);
    padding: var(--spacing-section) var(--spacing-lg);
    max-width: 1440px;
    margin: 0 auto;
  }

  .list-header {
    margin-bottom: var(--spacing-xl);
  }

  .list-title {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: 0;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .list-count {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-section) var(--spacing-lg);
    color: var(--ink-muted-48);
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
  }

  @media (max-width: 1068px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 834px) {
    .list-page {
      padding: 48px var(--spacing-sm);
    }

    .list-title {
      font-size: 34px;
    }

    .card-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  @media (max-width: 640px) {
    .list-title {
      font-size: 28px;
    }
  }
</style>