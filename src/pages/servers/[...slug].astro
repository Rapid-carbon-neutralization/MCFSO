---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const servers = await getCollection('servers');
  return servers
    .filter((entry) => entry.id !== 'index')
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout>
  <Header hideSearch={true} />
  <main class="detail-page">
    <a href="/servers" class="back-link">返回列表</a>
    <div class="server-header">
      <h1 class="server-name">{entry.data.name}</h1>
      <p class="server-desc">{entry.data.description}</p>
    </div>
    <article class="content">
      <Content />
    </article>
  </main>
</Layout>

<style>
  .detail-page {
    background: var(--canvas);
    padding: var(--spacing-section) var(--spacing-lg);
    max-width: 980px;
    margin: 0 auto;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
    color: var(--primary);
    display: inline-block;
    margin-bottom: var(--spacing-lg);
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .server-header {
    margin-bottom: var(--spacing-xl);
  }

  .server-name {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: 0;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .server-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink);
  }

  /* Markdown content styles */
  .content {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink);
  }

  .content :global(h3) {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 600;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink);
    margin-top: 2em;
    margin-bottom: 1em;
  }

  .content :global(p) {
    margin-bottom: 1em;
  }

  .content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }

  /* Ordered list */
  .content :global(ol) {
    margin-bottom: 1em;
    padding-left: 1.5em;
  }

  .content :global(ol li) {
    margin-bottom: 0.5em;
    color: var(--ink);
  }

  /* Unordered list */
  .content :global(ul) {
    margin-bottom: 1em;
    padding-left: 1.5em;
  }

  .content :global(ul li) {
    margin-bottom: 0.5em;
    color: var(--ink);
  }

  .content :global(ul ul) {
    margin-top: 0.5em;
    margin-bottom: 0;
  }

  /* Inline code */
  .content :global(code) {
    font-family: var(--font-body);
    font-size: 15px;
    background: var(--divider-soft);
    padding: 2px 6px;
    border-radius: var(--rounded-xs);
    color: var(--ink);
  }

  /* Links */
  .content :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  @media (max-width: 834px) {
    .detail-page {
      padding: 48px var(--spacing-sm);
    }

    .server-name {
      font-size: 34px;
    }
  }

  @media (max-width: 640px) {
    .server-name {
      font-size: 28px;
    }
  }
</style>