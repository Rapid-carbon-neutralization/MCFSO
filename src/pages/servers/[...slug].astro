---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const servers = await getCollection('servers');
  return servers
    .filter((entry) => entry.id !== 'index')
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout>
  <Header hideSearch={true} />
  <main class="detail-page">
    <div class="detail-header">
      <a href="/servers" class="back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5" />
          <path d="m12 19-7-7 7-7" />
        </svg>
        返回列表
      </a>
      <div class="server-info">
        <img src={entry.data.icon} alt="" class="detail-icon" width="64" height="64" />
        <div>
          <h1 class="detail-name">{entry.data.name}</h1>
          <p class="detail-desc">{entry.data.description}</p>
        </div>
      </div>
    </div>
    <hr class="divider" />
    <article class="content">
      <Content />
    </article>
  </main>
</Layout>

<style>
  .detail-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 24px 64px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 20px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .detail-header {
    margin-bottom: 20px;
  }

  .server-info {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .detail-icon {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    object-fit: contain;
    background: var(--bg-deep);
    flex-shrink: 0;
  }

  .detail-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.75rem;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .detail-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 32px;
  }

  .content {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-primary);
  }

  .content :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    margin-top: 2em;
    margin-bottom: 0.75em;
    color: var(--text-primary);
  }

  .content :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    color: var(--text-primary);
  }

  .content :global(p) {
    margin-bottom: 1em;
    color: var(--text-secondary);
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1em;
    padding-left: 1.5em;
    color: var(--text-secondary);
  }

  .content :global(li) {
    margin-bottom: 0.25em;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    margin: 1em 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-card);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
  }

  .content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    overflow-x: auto;
    margin: 1em 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: var(--text-primary);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0;
  }

  .content :global(th),
  .content :global(td) {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
    font-size: 0.9rem;
  }

  .content :global(th) {
    background: var(--bg-card);
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text-primary);
  }

  .content :global(td) {
    color: var(--text-secondary);
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content :global(a:hover) {
    color: var(--accent-hover);
  }

  .content :global(img) {
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 1em 0;
  }

  @media (max-width: 640px) {
    .detail-page {
      padding: 20px 16px 48px;
    }

    .detail-name {
      font-size: 1.35rem;
    }

    .detail-icon {
      width: 48px;
      height: 48px;
    }
  }
</style>
