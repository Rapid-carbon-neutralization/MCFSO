---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="hero">
    <div class="hero-content">
      <img src="/MCFSO.png" alt="MCFSO" class="hero-icon" width="80" height="80" />
      <h1 class="hero-title">MCFSO</h1>
      <p class="hero-subtitle">新生MC服务器宣传组织</p>
      <div class="hero-line">
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
        <span class="line-segment"></span>
      </div>
      <p class="hero-desc">
        发现优质的 Minecraft 新服务器，为每一位服主提供展示平台。
      </p>
      <a href="/servers" class="hero-cta">
        查找服务器
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </main>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 24px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 480px;
  }

  .hero-icon {
    width: 80px;
    height: 80px;
    border-radius: 16px;
    object-fit: contain;
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 3.5rem;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--text-secondary);
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  .hero-line {
    display: flex;
    gap: 4px;
    margin: 28px 0;
  }

  .line-segment {
    width: 24px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    transition: background 0.4s ease;
  }

  .hero-line:hover .line-segment {
    background: var(--accent);
  }

  .hero-line:hover .line-segment:nth-child(1) { transition-delay: 0.0s; }
  .hero-line:hover .line-segment:nth-child(2) { transition-delay: 0.08s; }
  .hero-line:hover .line-segment:nth-child(3) { transition-delay: 0.16s; }
  .hero-line:hover .line-segment:nth-child(4) { transition-delay: 0.24s; }
  .hero-line:hover .line-segment:nth-child(5) { transition-delay: 0.32s; }
  .hero-line:hover .line-segment:nth-child(6) { transition-delay: 0.4s; }
  .hero-line:hover .line-segment:nth-child(7) { transition-delay: 0.48s; }
  .hero-line:hover .line-segment:nth-child(8) { transition-delay: 0.56s; }

  .hero-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 360px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--accent);
    color: var(--bg-deep);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 10px;
    transition: background 0.2s, transform 0.2s;
  }

  .hero-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  .hero-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-icon {
      width: 60px;
      height: 60px;
    }

    .line-segment {
      width: 18px;
    }
  }
</style>
