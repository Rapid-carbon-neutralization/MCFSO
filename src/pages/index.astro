---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="hero-tile">
    <div class="hero-content">
      <h1 class="hero-title">MCFSO</h1>
      <p class="hero-tagline">新生MC服务器宣传组织</p>
      <p class="hero-body">
        发现优质的 Minecraft 新服务器，为每一位服主提供展示平台。
      </p>
      <div class="hero-ctas">
        <a href="/servers" class="cta-primary">查找服务器</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .hero-tile {
    background: var(--canvas-parchment);
    padding: var(--spacing-section) var(--spacing-lg);
    min-height: calc(100vh - 44px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    text-align: center;
    max-width: 980px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 600;
    line-height: 1.07;
    letter-spacing: -0.28px;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.14;
    letter-spacing: 0.196px;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .hero-body {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink);
    margin-bottom: 32px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .cta-primary {
    display: inline-block;
    padding: 11px 22px;
    background: var(--primary);
    color: var(--canvas);
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
    border-radius: var(--rounded-pill);
    transition: transform 0.15s;
  }

  .cta-primary:hover {
    transform: scale(0.95);
  }

  .cta-primary:active {
    transform: scale(0.95);
  }

  @media (max-width: 1068px) {
    .hero-title {
      font-size: 40px;
    }

    .hero-tagline {
      font-size: 24px;
    }
  }

  @media (max-width: 640px) {
    .hero-tile {
      padding: 48px var(--spacing-sm);
    }

    .hero-title {
      font-size: 34px;
    }

    .hero-tagline {
      font-size: 21px;
    }

    .hero-body {
      font-size: 15px;
    }
  }

  @media (max-width: 419px) {
    .hero-title {
      font-size: 28px;
    }
  }
</style>