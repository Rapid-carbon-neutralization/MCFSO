---
export interface Props {
  name: string;
  icon: string;
  description: string;
  slug: string;
}

const { name, icon, description, slug } = Astro.props;
---

<a href={`/servers/${slug}`} class="card" data-server-name={name.toLowerCase()}>
  <img src={icon} alt={`${name} 图标`} class="card-icon" width="64" height="64" loading="lazy" />
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    <p class="card-desc">{description}</p>
    <span class="card-link">了解更多</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--rounded-lg);
    padding: var(--spacing-lg);
    transition: transform 0.15s;
  }

  .card:hover {
    transform: scale(0.98);
  }

  .card:active {
    transform: scale(0.95);
  }

  .card:focus-visible {
    outline: 2px solid var(--primary-focus);
    outline-offset: 2px;
  }

  .card-icon {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border-radius: var(--rounded-sm);
    margin-bottom: 16px;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-name {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.24;
    letter-spacing: -0.374px;
    color: var(--ink);
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .card-link {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .card {
      padding: 20px;
    }

    .card-icon {
      width: 48px;
      height: 48px;
    }

    .card-name {
      font-size: 15px;
    }

    .card-desc {
      font-size: 15px;
    }
  }
</style>