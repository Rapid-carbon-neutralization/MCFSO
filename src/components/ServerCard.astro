---
export interface Props {
  name: string;
  icon: string;
  description: string;
  slug: string;
}

const { name, icon, description, slug } = Astro.props;
---

<a href={`/servers/${slug}`} class="card" data-server-name={name.toLowerCase()}>
  <img src={icon} alt={`${name} 图标`} class="card-icon" width="56" height="56" loading="lazy" />
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    <p class="card-desc">{description}</p>
  </div>
  <svg class="card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 12h14" />
    <path d="m12 5 7 7-7 7" />
  </svg>
</a>

<style>
  .card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.25s, background 0.25s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    background: var(--bg-surface);
    transform: translateY(-2px);
  }

  .card:focus-visible {
    border-color: var(--accent);
    outline: none;
  }

  .card-icon {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    object-fit: contain;
    background: var(--bg-deep);
    flex-shrink: 0;
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text-primary);
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-arrow {
    flex-shrink: 0;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .card:hover .card-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .card {
      padding: 12px;
    }

    .card-icon {
      width: 44px;
      height: 44px;
    }

    .card-name {
      font-size: 0.95rem;
    }
  }
</style>
