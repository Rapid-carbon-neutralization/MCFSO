---
const { hideSearch = false } = Astro.props;
---

<header class="header">
  <a href="/" class="logo-link">
    <img src="/MCFSO.png" alt="MCFSO" class="logo-icon" width="20" height="20" />
    <span class="logo-title">MCFSO</span>
  </a>
  {!hideSearch && (
    <div class="search-wrapper">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
      <input
        type="text"
        class="search-input"
        placeholder="搜索服务器..."
        id="server-search"
        data-search-input
      />
    </div>
  )}
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 44px;
    background: var(--surface-black);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .logo-title {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: -0.12px;
    color: var(--on-dark);
  }

  .search-wrapper {
    position: relative;
    max-width: 280px;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-muted-48);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    height: 26px;
    padding: 0 32px 0 34px;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--rounded-pill);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: -0.12px;
    transition: border-color 0.15s;
  }

  .search-input::placeholder {
    color: var(--ink-muted-48);
  }

  .search-input:focus {
    border-color: var(--primary-focus);
    outline: none;
  }

  @media (max-width: 834px) {
    .header {
      padding: 0 16px;
    }

    .logo-title {
      font-size: 11px;
    }

    .search-wrapper {
      max-width: 200px;
    }
  }
</style>